<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>点击拨号</title>
  <style>
    body { 
      display: flex; 
      justify-content: center; 
      align-items: center; 
      height: 100vh; 
      margin: 0; 
      font-family: sans-serif;
    }
    .call-btn { 
      font-size: 1.8rem; 
      padding: 1.2rem 3rem; 
      background: #007bff; 
      color: #fff; 
      text-decoration: none; 
      border-radius: 12px; 
      box-shadow: 0 4px 8px rgba(0,123,255,0.2);
    }
    .call-btn:hover {
      background: #0056b3;
    }
  </style>
</head>
<body>
  <a id="callBtn" class="call-btn" href="#">📞点击拨号</a>

  <script>
    const mixStr = "NDU5Mzk5MzM5ODE=|reverse|10"; 
    
    function decodePhone(str) {
      const [base64Str, method, radix] = str.split("|");
      let phone = atob(base64Str);
      if (method === "reverse") {
        phone = phone.split("").reverse().join("");
      }
      if (radix) {
        phone = phone.split("").map(c => parseInt(c, radix)).join("");
      }
      return phone;
    }

    const phoneNum = decodePhone(mixStr);
    document.getElementById("callBtn").href = "tel:" + phoneNum;

    document.getElementById("callBtn").addEventListener("contextmenu", (e) => {
      e.preventDefault();
    });
  </script>
</body>
</html>
